{
  "manifest_version": 3,
  "name": "Rosie",
  "version": "1.0.0",
  "description": "Intelligent web scraping and monitoring tool",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Rosie",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "tabs", "activeTab"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
